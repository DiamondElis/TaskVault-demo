{
  "name": "@taskvault/backend",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "build": "tsc -p tsconfig.build.json",
    "start": "node dist/src/index.js",
    "test": "vitest run",
    "test:watch": "vitest",
    "migrate:up": "tsx src/db/migrate-cli.ts up",
    "migrate:down": "tsx src/db/migrate-cli.ts down",
    "db:migrate": "tsx src/db/migrate-and-seed.ts"
  },
  "dependencies": {
    "@aws-sdk/client-s3": "^3.826.0",
    "@aws-sdk/client-secrets-manager": "^3.826.0",
    "@aws-sdk/client-sqs": "^3.826.0",
    "@aws-sdk/s3-request-presigner": "^3.826.0",
    "bcryptjs": "^3.0.2",
    "dotenv": "^16.6.1",
    "express": "^4.21.2",
    "jsonwebtoken": "^9.0.2",
    "lodash": "4.17.15",
    "multer": "^2.0.1",
    "node-pg-migrate": "^7.9.1",
    "pg": "^8.16.0",
    "prom-client": "^15.1.3",
    "uuid": "^11.1.0"
  },
  "devDependencies": {
    "@types/bcryptjs": "^2.4.6",
    "@types/express": "^5.0.2",
    "@types/jsonwebtoken": "^9.0.9",
    "@types/multer": "^1.4.12",
    "@types/node": "^22.15.21",
    "@types/pg": "^8.15.2",
    "@types/supertest": "^6.0.3",
    "supertest": "^7.1.1",
    "tsx": "^4.19.4",
    "typescript": "^5.8.3",
    "vitest": "^3.2.3"
  },
  "comments": {
    "lodash": "vuln-8: intentionally outdated for scanner correlation — not imported in app code"
  }
}
